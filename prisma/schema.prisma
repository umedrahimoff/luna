generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventFormat {
  ONLINE
  OFFLINE
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  /** Optional bio for host profile on public pages. */
  bio          String?
  /** Public handle for profile URL /u/{username} (lowercase). */
  username     String?  @unique
  /** Optional profile photo (path under /public, e.g. /uploads/avatars/1.png). */
  avatarUrl    String?
  /** Telegram user id (string) when account was created via Telegram. */
  telegramUserId String? @unique
  /** Login handle for Telegram auth (lowercase latin, unique). */
  loginSlug      String? @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       Event[]
  telegramAuthCodes TelegramAuthCode[]

  @@index([email])
  @@index([role])
}

/** One-time codes from the Telegram bot (signup or login). */
model TelegramAuthCode {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  telegramUserId String
  purpose        String
  userId         Int?
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramUserId])
  @@index([code])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]

  @@index([slug])
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  code2     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@index([slug])
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  countryId Int
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, slug])
  @@index([countryId])
  @@index([slug])
}

model Event {
  id            Int         @id @default(autoincrement())
  /** Public short code in URL: /{publicCode} (similar to luma.com/xxxx). */
  publicCode    String      @unique
  title         String
  description   String
  startsAt      DateTime
  endsAt        DateTime
  format        EventFormat
  location      String?
  locationMapUrl String?
  meetingUrl    String?
  capacity      Int?
  coverImageUrl String?
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  categoryId    Int?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  registrations Registration[]
  registrationQuestions EventRegistrationQuestion[]

  @@index([userId])
  @@index([startsAt])
  @@index([categoryId])
}

model Registration {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  email     String
  answersJson Json?
  createdAt DateTime @default(now())

  @@unique([eventId, email])
  @@index([eventId])
}

model EventRegistrationQuestion {
  id         Int      @id @default(autoincrement())
  eventId    Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type       String   @default("text")
  label      String
  placeholder String?
  optionsJson Json?
  required   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([eventId, sortOrder])
}
